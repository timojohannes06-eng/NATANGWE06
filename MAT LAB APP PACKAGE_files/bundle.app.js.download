                :host {
                    display: inline-block;
                    display: flex;
                    border-radius: 3px;
                    color: var(--mw-color-primary);
                    background-color: var(--mw-backgroundColor-input);
                    border: 1px solid var(--mw-borderColor-primary);
                    padding-left: 5px;
                }

                :host(:focus-within) {
                    border-color: var(--mw-borderColor-focus);

                }

                :host([disabled]) {
                    background-color: var(--mw-backgroundColor-input-readonly);
                }

                #mwIconContainer {
                    border-radius: 2px;
                    width: 28px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: default; /* modification from source: to prevent the search icon from clickable */
                }

                #mwClearIconContainer {
                    width: 24px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    margin-right: 5px;
                }

                #mwIconContainer[disabled] {
                    pointer-events: none;
                }

                #mwSearchInput {
                    color: inherit;
                    display: inline-block;
                    border: none;
                    border-top-right-radius: 3px;
                    border-bottom-right-radius: 3px;
                    flex: 1;
                    box-shadow: none;
                    margin: 0;
                    padding: 5px;
                    font-size: inherit;
                    font-style: inherit;
                    background: transparent;
                    min-width: 0;
                }

                ::placeholder {
                    color: var(--mw-color-secondary);
                }

                #mwSearchInput:focus {
                    outline:none;
                }

            `}static get properties(){return{tag:{type:String,reflect:!0,attribute:"data-tag"},dataType:{type:String,reflect:!0,attribute:"data-type"},disabled:{type:Boolean,reflect:!0},placeholder:{type:String,reflect:!0},readOnly:{type:Boolean,reflect:!0},shortcut:{type:String,reflect:!0},tabIndex:{type:Number,reflect:!0,attribute:"tabindex"},testId:{type:String,reflect:!0,attribute:"test-id"},value:{type:String},_hasFocus:{type:Boolean,attribute:!1}}}constructor(){super(),this.disabled=!1,this.placeholder="",this.tag="",this.readOnly=!1,this.shortcut="",this.tabIndex=0,this.testId="",this.value="",this._hasFocus=!1}firstUpdated(){this.shadowRoot.addEventListener("focusin",()=>{this.handleFocusIn()}),this.shadowRoot.addEventListener("focusout",()=>{this.handleFocusOut()})}update(e){e.has("disabled")&&(this.disabled?(this.tabIndex=-1,this.setAttribute("aria-disabled","")):(this.tabIndex=0,this.removeAttribute("aria-disabled"))),e.has("readOnly")&&(this.readOnly?this.setAttribute("aria-readonly",""):this.removeAttribute("aria-readonly")),super.update()}handleFocusIn(){this._hasFocus=!0,this.shadowRoot.querySelector("#mwSearchInput").select()}handleFocusOut(){this._hasFocus=!1}focus(){this.handleFocusIn(),this.shadowRoot.querySelector("#mwSearchInput").focus()}handleTextChange(e){e.stopPropagation();const t=e.target.value,n=this.value;this.emitEvent("input",{oldValue:n,newValue:t}),this.value=t}handleKeyDown(e){switch(e.key){case o.ENTER:e.stopPropagation(),e.preventDefault();const t=e.target.value;this.emitEvent("change",{value:t});break;case o.ESCAPE:""!==e.target.value&&(e.stopPropagation(),e.target.value="",this.value="",this.emitEvent("clear"))}}emitEvent(e,t={}){t.name=e;const n={detail:t,bubbles:!0,composed:!0};this.emit(e,t,n)}_handleClearIconClick(){this.value="",this.emitEvent("clear")}_handleSearchIconClick(){this.emitEvent("change",{value:this.value})}render(){let e=this.placeholder;return this.shortcut&&(e=`${this.placeholder} (${this.shortcut})`),t`
               <input
                    @input=${this.handleTextChange}
                    @keydown=${this.handleKeyDown}
                    placeholder=${e}
                    .value=${this.value}
                    id="mwSearchInput"
                    autocomplete="off"
                    aria-label=${e}
                    ?disabled=${this.disabled}
                    ?aria-disabled='${this.disabled}'
                    ?readonly=${this.readOnly}
                    ?aria-readonly='${this.readOnly}'
                    type='input'
                    data-type="Input"
                    maxlength='1024'
                />
                <div
                    tabindex=${this.disabled?"-1":"0"}
                    id="mwClearIconContainer"
                    ?disabled=${this.disabled}
                    ?aria-disabled='${this.disabled}'
                    ?readonly=${this.readOnly}
                    ?aria-readonly='${this.readOnly}'
                    style='display:${""!==this.value?"flex":"none"};'
                    @click=${this._handleClearIconClick}
                >
                    <mw-desktop-icon icon='{"id": "clearSearch", "width": 18, "height": 18}'></mw-desktop-icon>
                </div>
                <div
                    tabindex=${this.disabled?"-1":"0"}
                    id="mwIconContainer"
                    ?disabled=${this.disabled}
                    ?aria-disabled='${this.disabled}'
                    ?readonly=${this.readOnly}
                    ?aria-readonly='${this.readOnly}'
                    @click=${this._handleSearchIconClick}
                >
