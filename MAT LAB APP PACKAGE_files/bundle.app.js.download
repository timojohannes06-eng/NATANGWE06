C7JA,UAAA;EACE,WAAA;EACA,WAAA;EACA,YAAA;AD+LJ;;AA/BA;EACE,mBAAA;EC5JA,UAAA;EACE,WAAA;EACA,WAAA;EACA,SAAA;AD+LJ;;AAhCA;EACE,mBAAA;EACA,UAAA;EACA,WAAA;EACA,UAAA;EACA,SAAA;AAmCF;;AAjCA;EACE,mBAAA;EACA,UAAA;EACA,WAAA;EACA,UAAA;EACA,YAAA;AAoCF;AACA,49mCAA49mC",sourcesContent:['$filepath = get-file-path();\n@import get-file-depth($filepath) + processingRulesFile;\n\n/*******************************\n    Dialog\n*******************************/\n\nrulesets() {\n  .mwUnderlay {\n    background: $underlay-bg;\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    user-select: none;\n  }\n\n  .mwDialog {\n    background: $dialog-bg;\n    font-family: $dialog-font-family;\n    border-top: $dialog-border-top;\n    font-size: $dialog-font-size;\n    color: $dialog-font-color;\n    border-radius: 5px;\n    box-shadow: 0px 2px 5px 1px $dialog-box-shadow-color;\n    min-height: $dialog-min-height;\n    position: fixed;\n    visibility: hidden;\n    min-width: $dialog-min-width;\n    outline: none;\n    overflow: visible;\n    cursor: default;\n    user-select: none;\n\n    .mwDialogTitleBar {\n      background: $dialog-titlebar-bg;\n      overflow: hidden;\n      border-top-left-radius: 5px;\n      border-top-right-radius: 5px;\n      width: 100%;\n      height: 30px;\n      border-bottom: 1px solid $dialog-border-bottom;\n      cursor: move;\n\n      .mwTitleNode {\n        width: calc(100% - 40px);\n        overflow: hidden;\n        white-space: nowrap;\n        text-overflow: ellipsis;\n        font-size: $dialog-font-size;\n        font-weight: bold;\n        line-height: 14px;\n        color: $dialog-font-color;\n        vertical-align: top;\n        display: inline-block;\n        padding: 8px 10px 8px 10px;\n      }\n\n      .mwCloseNode {\n        position: absolute;\n        right: 0px;\n        width: 16px;\n        height: 16px;\n        margin: 7px;\n        cursor: default;\n\n        &:focus {\n          outline: 0;\n          width: 14px;\n          height: 14px;\n          border: 1px solid $closenode-border-focus;\n          border-radius: 3px;\n        }\n\n        &:focus .mwCloseSVG {\n          margin: 0px;\n        }\n        .mwCloseSVG {\n          background: image-url("ui-icons_close-black-12.svg") no-repeat;\n          background-size: 100% 100%;\n          opacity: 0.35;\n          width: 14px;\n          height: 14px;\n          position: absolute;\n          margin: 1px;\n\n          &:hover {\n            opacity: 0.5;\n          }\n        }\n      }\n    }\n\n    .mwDialogBody {\n      overflow: auto;\n      padding: 20px;\n      min-height: 37px;\n      height: calc(100% - 113px);\n\n      &.mwNoButtons {\n        min-height: 79px;\n        height: calc(100% - 71px);\n      }\n\n      .mwContentMessage {\n        user-select: text;\n      }\n\n      &.mwOverflow {\n        padding-bottom: 19px;\n        border-bottom: 1px solid $dialog-border-bottom;\n      }\n\n      &.mwNoButtons.mwOverflow {\n        padding-bottom: 20px;\n        border-bottom: none;\n      }\n      a {\n        color : $dialog-anchor-color;\n      }\n      a:visited {\n        color : $dialog-anchor-color-visited;\n      }\n    }\n  }\n\n  .mwDialogButtonBar {\n    overflow: hidden;\n    border-bottom-right-radius: 5px;\n    border-bottom-left-radius: 5px;\n    display: flex;\n    justify-content: space-between;\n    padding: 5px;\n\n    &.mwNoSplBtn {\n      justify-content: flex-end;\n\n      .mwActionButtonBar {\n        padding-left: 0px;\n      }\n    }\n\n    .mwSplButtonBar {\n      text-align: left;\n      padding-right: 5px;\n    }\n\n    .mwActionButtonBar {\n      text-align: right;\n      padding-left: 5px;\n    }\n\n    .mwButton {\n      background: $button-bg;\n      border-color: $button-border;\n      border-style: solid;\n      border-width: 1px;\n      border-radius: 5px;\n      display: inline-block;\n      font-size: $dialog-font-size;\n      padding-left: 8px;\n      padding-right: 8px;\n      margin: 5px;\n      line-height: 20px;\n      text-decoration: none;\n      text-align: center;\n      min-width: 68px;\n      position: relative;\n      transition: background-color .2s ease;\n      transition: color .2s ease;\n      cursor: default;\n      outline: none;\n      user-select: none;\n\n      &:hover {\n        background: $button-bg-hover;\n        border-color: $button-border-hover;\n      }\n\n      &:active:not(.mwDisabled), &.active:not(.mwDisabled) {\n        background: $button-bg-active;\n        border-color: $button-border-active;\n        box-shadow: $button-box-shadow-active;\n      }\n\n      &:focus:not(.mwDisabled) {\n        border-color: $button-border-focus;\n        border-width: 2px;\n        margin: 4px;\n      }\n\n      &.mwDefaultButton:not(.mwDisabled) {\n        border-width: 2px;\n        margin: 4px;\n        border-color: $default-button-border;\n      }\n\n      &.mwDisabled {\n        opacity: 0.35;\n      }\n    }\n  }\n}\n\nprefixer(rulesets);\nloadOverrides();',".mwUnderlay {\n  background: rgba(26,26,26,0.5);\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n}\n.mwDialog {\n  background: #f0f0f0;\n  font-family: 'Helvetica Neue', HeHelveticaNeue, Helvetica, Arial, sans-serif;\n  border-top: #f0f0f0;\n  font-size: 13px;\n  color: #404040;\n  border-radius: 5px;\n  box-shadow: 0px 2px 5px 1px rgba(0,0,0,0.5);\n  min-height: 160px;\n  position: fixed;\n  visibility: hidden;\n  min-width: 300px;\n  outline: none;\n  overflow: visible;\n  cursor: default;\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n}\n.mwDialog .mwDialogTitleBar {\n  background: #e6e6e6;\n  overflow: hidden;\n  border-top-left-radius: 5px;\n  border-top-right-radius: 5px;\n  width: 100%;\n  height: 30px;\n  border-bottom: 1px solid 