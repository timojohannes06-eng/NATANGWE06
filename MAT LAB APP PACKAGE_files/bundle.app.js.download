alog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-drive {\n    background: var(--mw-backgroundColor-tertiary) url("../../images/open_in_matlab.svg") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.mw-theme-dark .openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-drive {\n    background: var(--mw-backgroundColor-tertiary) url("../../images/open_in_matlab_dark_mode.svg") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-doc {\n    background: var(--mw-backgroundColor-tertiary) url("../../images/open_in_matlab_doc.png") no-repeat center;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-generic {\n    background: var(--mw-backgroundColor-tertiary) url("../../images/open_in_matlab_folder.png") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-close-button {\n    position: absolute;\n    top: 10px;\n    right: 12px;\n    z-index: 1;\n    margin: 0;\n    line-height: 14px;\n    padding: 0px;\n    height: 16px;\n    width: 16px;\n    border: none;\n    background-color: var(--mw-backgroundColor-tertiary);\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-close-button {\n    cursor: pointer;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-heading {\n    font-size: 19px;\n    padding: 20px 15px;\n    margin: 0;\n    font-family: \'Roboto\', sans-serif;\n    font-weight: 700;\n    color: var(--mw-color-primary);\n}\n\n.openwith-dialog-box.open-de