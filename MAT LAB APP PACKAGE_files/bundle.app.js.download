 sans-serif;\n}\n\n.open-desktop-confirmation-dialog .openwith-dialog-buttons .openwith-dialog-install-button {\n    border-radius: 4px;\n    border: 1px solid var(--mw-color-brand1);\n    background-color: var(--mw-color-brand1);\n    color:  var(--mw-backgroundColor-tertiary);\n    padding: 8px 14px;\n    margin: 5px;\n    text-align: center;\n    min-width: 68px;\n    font-size: 15px;\n}\n\n.open-desktop-confirmation-dialog .openwith-dialog-buttons .openwith-dialog-install-button:hover {\n    background-color: var(--mw-color-brand1);\n    cursor: pointer;\n}\n\n.open-desktop-confirmation-dialog .openwith-dialog-buttons .openwith-dialog-install-button:active {\n    background-color: var(--mw-color-brand1);\n    opacity: 0.7;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog {\n    padding-top: 20px;\n    width: 100%;\n    user-select: text;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .title-bar {\n    display: grid;\n    justify-content: space-between;\n    grid-template-columns: 10fr 1fr;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .mathworks-logo {\n    background-image: url("+p+");\n    background-size: 180px;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.mw-theme-dark .openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .mathworks-logo {\n    background-image: url("+b+");\n    background-size: 180px;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-drive {\n    background: var(--mw-backgroundColor-tertiary) url("+w+") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.mw-theme-dark .openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-drive {\n    background: var(--mw-backgroundColor-tertiary) url("+C+") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-doc {\n    background: var(--mw-backgroundColor-tertiary) url("+f+") no-repeat center;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .open-in-desktop-logo-generic {\n    background: var(--mw-backgroundColor-tertiary) url("+v+") no-repeat center top;\n    height: 40px;\n    background-repeat: no-repeat;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-close-button {\n    position: absolute;\n    top: 10px;\n    right: 12px;\n    z-index: 1;\n    margin: 0;\n    line-height: 14px;\n    padding: 0px;\n    height: 16px;\n    width: 16px;\n    border: none;\n    background-color: var(--mw-backgroundColor-tertiary);\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-close-button {\n    cursor: pointer;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .dialog-heading {\n    font-size: 19px;\n    padding: 20px 15px;\n    margin: 0;\n    font-family: 'Roboto', sans-serif;\n    font-weight: 700;\n    color: var(--mw-color-primary);\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .anchor_link {\n    text-decoration: none;\n    color: #069;\n    background: none;\n    border: none;\n    padding: 0;\n    font-size: 15px;\n    padding: 20px 0;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog .sub-text {\n    margin-top: 0;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog .mwDialogBody {\n    padding: 10px 20px;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog mw-mos-open-desktop-confirmation-dialog  .anchor_link:hover {\n    text-decoration: underline;\n    cursor: pointer;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog .dont-show-again-container {\n    font-size: 15px;\n    padding: 0 10px;\n    margin-top: 30px;\n}\n\n.openwith-dialog-box.open-desktop-confirmation-dialog .dont-show-again-container .dont-show-checkbox {\n    vertical-align: baseline;\n}\n\nmw-mos-open-desktop-confirmation-dialog .line-text {\n    font-size: 15px;\n    margin-top: 17px;\n    margin-bottom: 0px;\n    padding: 0 15px;\n}","",{version:3,sources:["webpack://./mw-open-with/dialogs/css/OpenDesktopConfirmationDialog.css"],names:[],mappings:"AAAA;IACI,uBAAuB;IACvB,oDAAoD;IACpD,8BAA8B;IAC9B,gBAAgB;IAChB,gBAAgB;IAChB,WAAW;IACX,iBAAiB;IACjB,iBAAiB;IACjB,mCAAmC;IACnC,kCAAkC;IAClC,iCAAiC;AACrC;;AAEA;IACI,kBAAkB;IAClB,wCAAwC;IACxC,wCAAwC;IACxC,0CAA0C;IAC1C,iBAAiB;IACjB,WAAW;IACX,kBAAkB;IAClB,eAAe;IACf,eAAe;AACnB;;AAEA;IACI,wCAAwC;IACxC,eAAe;AACnB;;AAEA;IACI,wCAAwC;IACxC,YAAY;AAChB;;AAEA;IACI,iBAAiB;IACjB,WAAW;IACX,iBAAiB;AACrB;;AAEA;IACI,aAAa;IACb,8BAA8B;IAC9B,+BAA+B;AACnC;;AAEA;IACI,yDAAoD;IACpD,sBAAsB;IACtB,YAAY;IACZ,4BAA4B;AAChC;;AAEA;IACI,yDAAyD;IACzD,sBAAsB;AAC1B;;AAEA;IACI,2GAA0G;IAC1G,YAAY;IACZ,4BAA4B;AAChC;;AAEA;IACI,2GAAoH;IACpH,YAAY;IACZ,4BAA4B;AAChC;;AAEA;IACI,uGAA0G;IAC1G,YAAY;IACZ,4BAA4B;AAChC;;AAEA;IACI,2GAAiH;IACjH,YAAY;IACZ,4BAA4B;AAChC;;AAEA;IACI,kBAAkB;IAClB,SAAS;IACT,WAAW;IACX,UAAU;IACV,SAAS;IACT,iBAAiB;IACjB,YAAY;IACZ,YAAY;IACZ,WAAW;IACX,YAAY;IACZ,oDAAoD;AACxD;;AAEA;IACI,eAAe;AACnB;;AAEA;IACI,eAAe;IACf,kBAAkB;IAClB,SAAS;IACT,iCAAiC;IACjC,gBAAgB;IAChB,8BAA8B;AAClC;;AAEA;IACI,qBAAqB;IACrB,WAAW;IACX,gBAAgB;IAChB,YAAY;IACZ,UAAU;IACV,eAAe;IACf,eAAe;AACnB;;AAEA;IACI,aAAa;AACjB;;AAEA;IACI,kBAAkB;AACtB;;AAEA;IACI,0BAA0B;IAC1B,eAAe;AACnB;;AAEA;IACI,eAAe;IACf,eAAe;IACf,gBAAgB;AACpB;;AAEA;IACI,wBAAwB;AAC5B;;AAEA;IACI,eAAe;IACf,gBAAgB;IAChB,kBAAkB;IAClB,eAAe;AACnB",sourcesContent:['.openwith-dialog-box.open-desktop-confirmation-dialog {\n   