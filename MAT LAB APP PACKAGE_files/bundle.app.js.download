n}\n\nmw-mos-home-freemium-warning-dialog .license-content {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    column-gap: 25px;\n    margin-top: 20px;\n    grid-auto-rows: 1fr;\n    row-gap: 20px;\n}\n\n@media (min-width: 1920px)  {\n    mw-mos-home-freemium-warning-dialog .license-content {\n        column-gap: 25px;\n    }\n}\n\n@media only screen and (max-width: 1500px) {\n    mw-mos-home-freemium-warning-dialog .license-content {\n        column-gap: 25px;\n    }\n}\n\n@media only screen and (max-width: 1080px) {\n    mw-mos-home-freemium-warning-dialog .license-content {\n        column-gap: 25px;\n    }\n}\n\n@media only screen and (max-width: 1020px) {\n    mw-mos-home-freemium-warning-dialog .license-content {\n        grid-template-columns: 1fr 1fr;\n        column-gap: 50px;\n    }\n}\n\n@media screen and (max-width: 670px) {\n    mw-mos-home-freemium-warning-dialog .license-content {\n        grid-template-columns: 1fr;\n    }\n}\n\nmw-mos-home-freemium-warning-dialog .line-text:first-of-type {\n    margin-top: 15px;\n    margin-bottom: 25px;\n}\n\nmw-mos-home-freemium-warning-dialog .line-text {\n    margin-top: 25px;\n    margin-bottom: 10px;\n}\n\nmw-mos-home-freemium-warning-dialog .link-button {\n    background: none!important;\n    border: none;\n    padding: 0!important;\n    color: #069;\n    cursor: pointer;\n}\n\nmw-mos-home-freemium-warning-dialog .link-button:hover {\n    text-decoration: underline;\n}'],sourceRoot:""}]);const m=d},6521(e,t,n){"use strict";n.d(t,{A:()=>p});var o=n(/*! ../../../../../node_modules/css-loader/dist/runtime/cssWithMappingToString.js */9372),i=n.n(o),r=n(/*! ../../../../../node_modules/css-loader/dist/runtime/api.js */40935),s=n.n(r),a=n(/*! ../../../../../node_modules/css-loader/dist/runtime/getUrl.js */20062),c=n.n(a),l=n(/*! ../../images/membrane_blue.png */45639),d=n(/*! ../../images/matlab_logo_wordmark.svg */93939),u=n(/*! ../../images/mathworks_logo.png */14335),m=s()(i()),A=c()(l),h=c()(d),g=c()(u);m.push([e.id,"mw-mos-home-loading-screen {\n    display: none;\n}\n\nmw-mos-home-loading-screen.shown {\n    display: block;\n}\n\n.loading-screen-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: 99;\n    background-color: var(--mw-backgroundColor-active);\n}\n\n.loading-screen-card {\n    --ls-card-width: 800px;\n    --ls-card-height: 450px;\n    --ls-left-width: 375px;\n    --ls-tip-max-width: 330px;\n\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    display: flex;\n    flex-direction: row;\n    width: var(--ls-card-width);\n    height: var(--ls-card-height);\n    border-radius: 8px;\n    background: #fff url("+A+") left top / auto 100% no-repeat;\n    box-shadow: 0 1px 3px 0px var(--mw-boxShadowColor);\n    overflow: hidden;\n}\n\n.loading-screen-left {\n    flex: 0 0 var(--ls-left-width);\n    height: 100%;\n    position: relative;\n}\n\n.loading-screen-matlab-logo {\n    position: absolute;\n    top: 170px;\n    left: 38px;\n    z-index: 1;\n    width: 300px;\n    height: 60px;\n    background-image: url("+h+");\n    background-size: 300px auto;\n    background-repeat: no-repeat;\n}\n\n.loading-screen-mathworks-logo {\n    position: absolute;\n    bottom: 15px;\n    left: 20px;\n    width: 150px;\n    height: 31px;\n    background-image: url("+g+");\n    background-size: contain;\n    background-repeat: no-repeat;\n}\n\n.loading-screen-right {\n    flex: 1;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 0 48px;\n}\n\n.loading-screen-spinner {\n    margin-bottom: 48px;\n}\n\n\n.loading-screen-tip {\n    max-width: var(--ls-tip-max-width);\n    text-align: center;\n    font-family: Roboto, sans-serif;\n    font-size: 15px;\n    font-weight: 400;\n    font-style: normal;\n    line-height: normal;\n    color: var(--mw-color-secondary);\n}\n\n.loading-screen-tip:empty {\n    display: none;\n}\n\n.loading-screen-tip a {\n    color: var(--mw-color-hyperlink);\n    font-family: Roboto, sans-serif;\n    font-size: 15px;\n    font-weight: 400;\n    line-height: normal;\n    text-decoration-line: underline;\n    text-decoration-style: solid;\n    text-decoration-skip-ink: auto;\n    text-decoration-thickness: auto;\n    text-underline-offset: auto;\n    text-underline-position: from-font;\n}\n\n.loading-screen-tip strong,\n.loading-screen-tip b {\n    font-weight: bold;\n}\n\n.loading-screen-tip code {\n    font-family: monospace;\n}\n\n/* Breakpoint matches card width: single-column layout when viewport is narrower */\n@media screen and (max-width: 800px) {\n    .loading-screen-card {\n        width: 100%;\n        height: var(--ls-card-height);\n        background: #fff;\n    }\n\n    .loading-screen-left {\n        display: none;\n    }\n\n    .loading-screen-mathworks-logo {\n        display: none;\n    }\n}\n","",{version:3,sources:["webpack://./mw-home-ui/dialogs/css/LoadingScreen.css"],names:[],mappings:"AAAA;IACI,aAAa;AACjB;;AAEA;IACI,cAAc;AAClB;;AAEA;IACI,eAAe;IACf,MAAM;IACN,OAAO;IACP,WAAW;IACX,YAAY;IACZ,WAAW;IACX,kDAAkD;AACtD;;AAEA;IACI,sBAAsB;IACtB,uBAAuB;IACvB,sBAAsB;IACtB,yBAAyB;;IAEzB,kBAAkB;IAClB,QAAQ;IACR,SAAS;IACT,gCAAgC;IAChC,aAAa;IACb,mBAAmB;IACnB,2BAA2B;IAC3B,6BAA6B;IAC7B,kBAAkB;IAClB,uFAAqF;IACrF,kDAAkD;IAClD,gBAAgB;AACpB;;AAEA;IACI,8BAA8B;IAC9B,YAAY;IACZ,kBAAkB;AACtB;;AAEA;IACI,kBAAkB;IAClB,UAAU;IACV,UAAU;IACV,UAAU;IACV,YAAY;IACZ,YAAY;IACZ,yDAA8D;IAC9D,2BAA2B;IAC3B,4BAA4B;AAChC;;AAEA;IACI,kBAAkB;IAClB,YAAY;IACZ,UAAU;IACV,YAAY;IACZ,YAAY;IACZ,yDAAwD;IACxD,wBAAwB;IACxB,4BAA4B;AAChC;;AAEA;IACI,OAAO;IACP,YAAY;IACZ,sBAAsB;IACtB,aAAa;IACb,sBAAsB;IACtB,mBAAmB;IACnB,uBAAuB;IACvB,eAAe;AACnB;;AAEA;IACI,mBAAmB;AACvB;;;AAGA;IACI,kCAAkC;IAClC,kBAAkB;IAClB,+BAA+B;IAC/B,eAAe;IACf,gBAAgB;IAChB,kBAAkB;IAClB,mBAAmB;IACnB,gCAAgC;AACpC;;AAEA;IACI,aAAa;AACjB;;AAEA;IACI,gCAAgC;IAChC,+BAA+B;IAC/B,eA