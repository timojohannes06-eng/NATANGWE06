-card.middle {\n  justify-self: center;\n}\n\nmw-mos-home-course-card.right {\n  justify-self: right;\n}\n\nmw-mos-home-course-card .course-card {\n  border: none;\n  padding: 0;\n  cursor: pointer;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  width: 100%;\n  background-color: var(--mw-color-tertiary);\n}\n\nmw-mos-home-course-card .course-info {\n  box-sizing: border-box;\n  border: 1px solid var(--mw-borderColor-secondary);\n  width: 100%;\n  display: flex;\n  flex: 1 1 0;\n  flex-direction: column;\n  justify-content: space-between;\n  background-color: var(--mw-backgroundColor-tertiary);\n}\n\nmw-mos-home-course-card .avatar {\n  background-image: url("+u+");\n  background-size: cover;\n  height: 100px;\n  width: 100%;\n  background-position: center;\n}\n\nmw-mos-home-course-card .course-card:hover {\n  opacity: 0.8;\n}\n\nmw-mos-home-course-card .title-area {\n  padding: 10px;\n}\n\nmw-mos-home-course-card .progress-widget {\n  padding: 5px 10px 10px;\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n}\n\nmw-mos-home-course-card .course-action {\n  color: var(--mw-color-hyperlink);\n  font-size: 14px;\n  text-align: left;\n}\n\nmw-mos-home-course-card progress {\n  -webkit-appearance: none;\n  -moz-appearance: none;\n  appearance: none;\n  height: 5px;\n  border: 0px;\n  color: var(--mw-backgroundColor-currentLineExecutionBrick); \n  width: 100%;\n  margin-top: 5px;\n}\n\nmw-mos-home-course-card .progress-value {\n  font-size: 12px;\n  padding-left: 10px;\n}\n\nmw-mos-home-course-card progress[value]::-webkit-progress-bar {\n  background-color: #f5f5f5;\n}\n\nmw-mos-home-course-card progress[value]::-webkit-progress-value {\n  background-color: var(--mw-backgroundColor-currentLineExecutionBrick);\n}\n\nmw-mos-home-course-card progress[value]::-moz-progress-bar { \n  background-color: var(--mw-backgroundColor-currentLineExecutionBrick);\n}\n\nmw-mos-home-course-card .course-name {\n  color: var(--mw-color-primary);\n  font-size: 14px;\n  font-weight: 600;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 3;\n  -webkit-box-orient: vertical;\n  white-space: normal;\n  direction: ltr;\n  text-align: left;\n  width: 100%;\n}\n\nmw-mos-home-course-card .access-expiry { \n  float: left;\n  font-size: 12px;\n  color: var(--mw-color-secondary);\n}","",{version:3,sources:["webpack://./mw-home-ui/sections/Training/css/CourseCard.css"],names:[],mappings:"AAAA;EACE,gBAAgB;EAChB,WAAW;AACb;;AAEA;EACE,kBAAkB;AACpB;;AAEA;EACE,oBAAoB;AACtB;;AAEA;EACE,mBAAmB;AACrB;;AAEA;EACE,YAAY;EACZ,UAAU;EACV,eAAe;EACf,aAAa;EACb,sBAAsB;EACtB,YAAY;EACZ,WAAW;EACX,0CAA0C;AAC5C;;AAEA;EACE,sBAAsB;EACtB,iDAAiD;EACjD,WAAW;EACX,aAAa;EACb,WAAW;EACX,sBAAsB;EACtB,8BAA8B;EAC9B,oDAAoD;AACtD;;AAEA;EACE,yDAAiE;EACjE,sBAAsB;EACtB,aAAa;EACb,WAAW;EACX,2BAA2B;AAC7B;;AAEA;EACE,YAAY;AACd;;AAEA;EACE,aAAa;AACf;;AAEA;EACE,sBAAsB;EACtB,aAAa;EACb,8BAA8B;EAC9B,qBAAqB;AACvB;;AAEA;EACE,gCAAgC;EAChC,eAAe;EACf,gBAAgB;AAClB;;AAEA;EACE,wBAAwB;EACxB,qBAAqB;EACrB,gBAAgB;EAChB,WAAW;EACX,WAAW;EACX,0DAA0D;EAC1D,WAAW;EACX,eAAe;AACjB;;AAEA;EACE,eAAe;EACf,kBAAkB;AACpB;;AAEA;EACE,yBAAyB;AAC3B;;AAEA;EACE,qEAAqE;AACvE;;AAEA;EACE,qEAAqE;AACvE;;AAEA;EACE,8BAA8B;EAC9B,eAAe;EACf,gBAAgB;EAChB,gBAAgB;EAChB,uBAAuB;EACvB,oBAAoB;EACpB,qBAAqB;EACrB,4BAA4B;EAC5B,mBAAmB;EACnB,cAAc;EACd,gBAAgB;EAChB,WAAW;AACb;;AAEA;EACE,WAAW;EACX,eAAe;EACf,gCAAgC;AAClC",sourcesContent:['mw-mos-home-course-card {\n  margin-top: 10px;\n  width: 100%;\n}\n\nmw-mos-home-course-card.left {\n  justify-self: left;\n}\n\nmw-mos-home-course-card.middle {\n  justify-self: center;\n}\n\nmw-mos-home-course-card.right {\n  justify-self: right;\n}\n\nmw-mos-home-course-card .course-card {\n  border: none;\n  padding: 0;\n  cursor: pointer;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  width: 100%;\n  background-color: var(--mw-color-tertiary);\n}\n\nmw-mos-home-course-card .course-info {\n  box-sizing: border-box;\n  border: 1px solid var(--mw-borderColor-secondary);\n  width: 100%;\n  display: flex;\n  flex: 1 1 0;\n  flex-direction: column;\n  justify-content: space-between;\n  background-color: var(--mw-backgroundColor-tertiary);\n}\n\nmw-mos-home-course-card .avatar {\n  background-image: url("../../../images/panel_gettingstarted.jpg");\n  background-size: cover;\n  height: 100px;\n  width: 100%;\n  background-position: center;\n}\n\nmw-mos-home-course-card .course-card:hover {\n  opacity: 0.8;\n}\n\nmw-mos-home-course-card .title-area {\n  padding: 10px;\n}\n\nmw-mos-home-course-card .progress-widget {\n  padding: 5px 10px 10px;\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n}\n\nmw-mos-home-course-card .course-action {\n  color: var(--mw-color-hyperlink);\n  font-size: 14px;\n  text-align: left;\n}\n\nmw-mos-home-course-card progress {\n  -webkit-appearance: none;\n  -moz-appearance: none;\n  appearance: none;\n  height: 5px;\n  border: 0px;\n  color: var(--mw-backgroundColor-currentLineExecutionBrick); \n  width: 100%;\n  margin-top: 5px;\n}\n\nmw-mos-home-course-card .progress-value {\n  font-size: 12px;\n  padding-left: 10px;\n}\n\nmw-mos-home-course-card progress[value]::-webkit-progress-bar {\n  background-color: #f5f5f5;\n}\n\nmw-mos-home-course-card progress[value]::-webkit-progress-value {\n  background-color: var(--mw-backgroundColor-currentLineExecutionBrick);\n}\n\nmw-mos-home-course-card progress[value]::-moz-progress-bar { \n  background-color: var(--mw-backgroundColor-currentLineExecutionBrick);\n}\n\nmw-mos-home-course-card .course-name {\n  color: var(--mw-color-primary);\n  font-size: 14px;\n  font-weight: 600;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 3;\n  -webkit-box-orient: vertical;\n  white-space: normal;\n  direction: ltr;\n  text-align: left;\n  width: 100%;\n}\n\nmw-mos-home-course-card .access-expiry { \n  float: left;\n  font-size: 12px;\n  color: var(--mw-color-secondary);\n}'],sourceRoot:""}]);const m=d},71873(e,t,n){"use strict";n.d(t,{A:()=>a});var o=n(/*! ../../../../node_modules/css-loader/dist/runtime/cssWithMappingToString.js */9372),i=n.n(o),r=n(/*! ../../../../node_modules/css-loader/dist/runtime/api.js */40935),s=n.n(r)()(i());s.push([e.id,"/*\n * Copyright 2019-2023 The MathWorks, Inc.\n */\n\n.mw-login-widget {\n    height: 100%;\n    overflow: hidden;\n    position: relative;\n}\n\n.mw-login-frame {\n    width: 100%;\n    height: 100%;\n    border: 0;\n}\n\n.mw-login-dialog.mwDialog {\n    min-height: 450px;\n}\n\n.mw-login-dialog.mwDialog .mwDialogBody {\n    /* override embedded-styles which messes with the contents of the mw-dialog */\n    box-sizing: content-box;\n    padding: 0; /* Gets rid of the white/black padding around the embedded login iframe */\n}\n\n.mw-login-dialog-no-title.mwDialog {\n    min-height: 420px;\n}\n\n.mw-login-dialog-no-title.mwDialog .mwDialogTitleBar {\n    display: none;\n}\n\n.mw-login-dialog-no-title.mwDialog .mwDialogBody {\n    background: white;\n    height: calc(100% - 42px);\n}\n\n.mw-logout-widget {\n    background-color: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 20px;\n    height: 100%;\n}\n\n.mw-logout-widget-message {\n    height: 100%;\n    width: 100%;\n}\n\n.mw-logout-widget-message .mwIconAndMessageWidgetIcon {\n    box-sizing: content-box;\n}\n\n.mw-logout-widget-message .mwIconAndMessageWidgetMessage {\n    height: 100%;\n}\n\n.mw-logout-widget-buttons {\n    margin-top: 8px;\n    align-self: flex-end;\n}\n\n.mw-logout-widget-buttons .mwPushButton {\n    min-width: 68px; /* To match mw-dialogs */\n    margin: 0 2px;\n}\n\n.mw-login-widget-spinner {\n    display: flex;\n    height: 100%;\n    width: 100%;\n    align-items: center;\n    justify-content: center;\n    flex-direction: column;\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: white;\n}\n\n.mw-login-widget-spinner-text {\n    padding: 1em 2em;\n    height: 1em;\n    overflow: visible;\n}\n","",{version:3,sources:["webpack://./mw-login/css/app.css"],names:[],mappings:"AAAA;;EAEE;;AAEF;IACI,YAAY;IACZ,gBAAgB;IAChB,kBAAkB;AACtB;;AAEA;IACI,WAAW;IACX,YAAY;IACZ,SAAS;AACb;;AAEA;IACI,iBAAiB;AACrB;;AAEA;IACI,6EAA6E;IAC7E,uBAAuB;IACvB,UAAU,EAAE,yEAAyE;AACzF;;AAEA;IACI,iBAAiB;AACrB;;AAEA;IACI,aAAa;AACjB;;AAEA;IACI,iBAAiB;IACjB,yBAAyB;AAC7B;;AAEA;IACI,yBAAyB;IACzB,aAAa;IACb,sBAAsB;IACtB,mBAAmB;IACnB,aAAa;IACb,YAAY;AAChB;;AAEA;IACI,YAAY;IACZ,WAAW;AACf;;AAEA;IACI,uBAAuB;AAC3B;;AAEA;IACI,YAAY;AAChB;;AAEA;IACI,eAAe;IACf,oBAAoB;AACxB;;AAEA;IACI,eAAe,EAAE,wBAAwB;IACzC,aAAa;AACjB;;AAEA;IACI,aAAa;IACb,YAAY;IACZ,WAAW;IACX,mBAAmB;IACnB,uBAAuB;IACvB,sBAAsB;IACtB,kBAAkB;IAClB,OAAO;IACP,MAAM;IACN,iBAAiB;AACrB;;AAEA;IACI,gBAAgB;IAChB,WAAW;IACX,iBAAiB;AACrB",sourcesContent:["/*\n * Copyright 2019-2023 The MathWorks, Inc.\n */\n\n.mw-login-widget {\n    height: 100%;\n    overflow: hidden;\n    position: relative;\n}\n\n.mw-login-frame {\n    width: 100%;\n    height: 100%;\n    border: 0;\n}\n\n.mw-login-dialog.mwDialog {\n    min-height: 450px;\n}\n\n.mw-login-dialog.mwDialog .mwDialogBody {\n    /* override embedded-styles which messes with the contents of the mw-dialog */\n    box-sizing: content-box;\n    padding: 0; /* Gets rid of the white/black padding around the embedded login iframe */\n}\n\n.mw-login-dialog-no-title.mwDialog {\n    min-height: 420px;\n}\n\n.mw-login-dialog-no-title.mwDialog .mwDialogTitleBar {\n    display: none;\n}\n\n.mw-login-dialog-no-title.mwDialog .mwDialogBody {\n    background: white;\n    height: calc(100% - 42px);\n}\n\n.mw-logout-widget {\n    background-color: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 20px;\n    height: 100%;\n}\n\n.mw-logout-widget-message {\n    height: 100%;\n    width: 100%;\n}\n\n.mw-logout-widget-message .mwIconAndMessageWidgetIcon {\n    box-sizing: content-box;\n}\n\n.mw-logout-widget-message .mwIconAndMessageWidgetMessage {\n    height: 100%;\n}\n\n.mw-logout-widget-buttons {\n    margin-top: 8px;\n    align-self: flex-end;\n}\n\n.mw-logout-widget-buttons .mwPushButton {\n    min-width: 68px; /* To match mw-dialogs */\n    margin: 0 2px;\n}\n\n.mw-login-widget-spinner {\n    display: flex;\n    height: 100%;\n    width: 100%;\n    align-items: center;\n    justify-content: center;\n    flex-direction: column;\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: white;\n}\n\n.mw-login-widget-spinner-text {\n    padding: 1em 2em;\n    height: 1em;\n    overflow: visible;\n}\n"],sourceRoot:""}]);const a=s},63861(e,t,n){"use strict";n.d(t,{A:()=>l});var o=n(/*! ../../../../node_modules/css-loader/dist/runtime/cssWithMappingToString.js */9372),i=n.n(o),r=n(/*! ../../../../node_modules/css-loader/dist/runtime/api.js */40935),s=n.n(r),a=n(/*! -!../../../../node_modules/css-loader/dist/cjs.js!./app.css */71873),c=s()(i());c.i(a.A),c.push([e.id,"/*\n * Copyright 2019 The MathWorks, Inc.\n */\n\n/* Main application .css file */\n","",{version:3,sources:["webpack://./mw-login/css/main.css"],names:[],mappings:"AAAA;;EAEE;;AAEF,+BAA+B",sourcesContent:['/*\n * Copyright 2019 The MathWorks, Inc.\n */\n\n/* Main application .css file */\n@import "app.css";\n'],sourceRoot:""}]);const l=c},71727(e,t,n){"use strict";n.d(t,{A:()=>a});var o=n(/*! ../../../../node_modules/css-loader/dist/runtime/cssWithMappingToString.js */9372),i=n.n(o),r=n(/*! ../../../../node_modules/css-loader/dist/runtime/api.js */40935),s=n.n(r)()(i());s.push([e.id,'/** css variables to expose */\nmw-matrix {\n  --mw-matrix-waffle-icon-color: var(--mw-color-gray700, #616161);\n  --mw-matrix-waffle-icon-color-hover: var(--mw-color-gray800, #333);\n  --mw-matrix-waffle-icon-color-focus: var(--mw-color-gray800, #333);\n  --mw-matrix-link-color: var(--mw-ws-global-link-color, var(--mw-color-blue550, #1171be));\n  --mw-matrix-link-color-hover: var(--mw-ws-global-link-hover-color, var(--mw-color-blue500, #268cdd));\n}\n\n/* from boostrap 3 stylesheet */\nmw-matrix *,\nmw-matrix *::before,\nmw-matrix *::after {\n  box-sizing: border-box;\n}\n\nmw-matrix * {\n  -webkit-box-sizing: border-box;\n  -moz-box-sizing: border-box;\n  box-sizing: border-box\n}\n\nmw-matrix button,\nmw-matrix input,\nmw-matrix select,\nmw-matrix textarea {\n  font-family: inherit;\n  font-size: inherit;\n  line-height: inherit;\n  color: inherit;\n  font: inherit;\n  margin: 0;\n}\n\nmw-matrix button,\nmw-matrix html input[type=button],\nmw-matrix input[type=reset],\nmw-matrix input[type=submit] {\n  -webkit-appearance: button;\n  cursor: pointer;\n}\n\nmw-matrix button,\nmw-matrix select {\n  text-transform: none;\n}\n\nmw-matrix optgroup {\n  color: inherit;\n  font: inherit;\n  margin: 0\n}\n\nmw-matrix article,\nmw-matrix aside,\nmw-matrix details,\nmw-matrix figcaption,\nmw-matrix figure,\nmw-matrix footer,\nmw-matrix header,\nmw-matrix hgroup,\nmw-matrix main,\nmw-matrix menu,\nmw-matrix nav,\nmw-matrix section,\nmw-matrix summary {\n  display: block\n}\n\nmw-matrix .list-unstyled {\n  padding-left: 0;\n  list-style: none;\n}\n\nmw-matrix ol,\nmw-matrix ul {\n  margin-top: 0;\n  margin-bottom: 10px\n}\n\nmw-matrix img {\n  vertical-align: middle;\n}\n\n/* from site7 stylesheet */\nmw-matrix button[class*="icon-"],\nmw-matrix span[class*="icon-"]:not(.glyphicon) {\n  border:1px solid transparent;\n  display:inline-block;\n  font-family:\'mathworks\';\n  font-style:normal;\n  -moz-osx-font-smoothing:grayscale;\n  -webkit-font-smoothing:antialiased;\n  font-variant:normal;\n  font-weight:normal;\n  text-transform:none;\n  speak:none\n}\n\nmw-matrix ul.list-unstyled {\n  margin-left: 0;\n}\n\nmw-matrix ul li {\n  padding: 0 0 0 20px;\n  margin: 0 0 7px;\n  background: 0;\n  list-style-type: none;\n}\n\nmw-matrix ul.list-unstyled li {\n  padding-left: 0;\n}\n\nmw-matrix a {\n  color: var(--mw-matrix-link-color);\n  text-decoration: none;\n}\n\nmw-matrix a:visited {\n  color: var(--mw-matrix-link-color);\n  text-decoration: none;\n}\n\nmw-matrix a.svg_link {\n  display: inline-block;\n  position: relative;\n  transition: opacity .3s ease;\n}\n\nmw-matrix a.svg_link:after {\n  bottom: 0;\n  content: "";\n  left: 0;\n  position: absolute;\n  right: 0;\n  top: 0;\n}\n\n/** mw-matrix custom styles */\nmw-matrix {\n  position: relative;\n}\n\nmw-matrix button { \n  width:24px; \n  height:24px; \n  padding:0;\n  border: none;\n  background:none transparent; \n  display:inline-block;\n  transition:color .3s ease;\n  position: relative;\n  overflow: visible;\n}\n\nmw-matrix button > .icon-matrix { fill: var(--mw-matrix-waffle-icon-color); font-size:24px; line-height:1.00 !important;}\nmw-matrix button:hover > .icon-matrix { fill: var(--mw-matrix-waffle-icon-color-hover); }\nmw-matrix button:focus > .icon-matrix { fill: var(--mw-matrix-waffle-icon-color-focus); }\n\nmw-matrix .icon-matrix:before {\n  display: none;\n}\n\nmw-matrix mw-matrix-mobile-button .icon-matrix:before {\n  display: inline-block;\n}\n\n/* Default view for Matrix when Scrollable */\nmw-matrix .matrix_container.add_scrollable {\n  max-height: 100vh;\n  overflow-y: visible;\n}\n\n/* \n   Targeting "Short" Viewports \n   Add vertical scrollbar when device height is too small\n*/\n@media screen and (max-height: 600px) {\n  mw-matrix .matrix_container.add_scrollable {\n    max-height: calc(100vh - 48px);\n    overflow-y: auto; \n  }\n}\n\n/**\n * ----------------------------------------\n * Matrix Animations\n * ----------------------------------------\n */\n\n.mw_matrix_collapse:not(.mw_matrix_show) {\n  display: none;\n}\n\n/* MATRIX MENU TABLET AND MOBILE */\n#header_mobile mw-matrix .matrix_container,\n#header_mobile .matrix_container_mobile { \n  margin:1px auto 0; \n  border:none; \n  box-shadow:none; \n  background:#fff; \n  float:none; \n  overflow:hidden; \n  position:relative;\n  z-index:3;\n  display:block !important; \n  height:auto !important;\n}\n#header_mobile .headernav_matrix > button,\n#header_mobile .matrix_affordance_container_mobile mw-matrix button { \n  width:auto; \n  min-width:37px; \n  height:auto; \n  min-height:37px; \n  margin:3.5px -1.5px 0 0; \n  float:right; \n}\n#header_mobile .headernav_matrix mw-matrix button > .icon-matrix,\n#header_mobile .matrix_affordance_container_mobile mw-matrix button > .icon-matrix { color:#0076a8; }\n\n/* DESKTOP MATRIX MENU */\nmw-matrix .matrix_container,\n.matrix_container_mobile { \n  width:319px; \n  padding:0 10px 10px; \n  margin-top:2px; \n  border:1px solid #999; \n  background:#fff; \n  box-shadow:0 1px 3px 0 rgba(0,0,0,0.25); \n  float:right; \n  overflow:hidden; \n  position:absolute; \n  right:0; \n  z-index:1037; \n}\n\nmw-matrix .matrix_container ul.matrix_links_primary,\n.matrix_container_mobile ul.matrix_links_primary,\n.matrix_container.mw_matrix_bs_5 ul.matrix_links_primary { \n  border-bottom:1px solid #ccc; \n}\nmw-matrix .matrix_container ul[class*="matrix_links_"],\n.matrix_container_mobile ul[class*="matrix_links_"],\n.matrix_container.mw_matrix_bs_5 ul[class*="matrix_links_"] { \n  width:100%; \n  padding:10px 0 0; \n  margin-bottom:0; \n  float:left; \n} \nmw-matrix .matrix_container ul[class*="matrix_links_"] > li,\n.matrix_container_mobile ul[class*="matrix_links_"] > li,\n.matrix_container.mw_matrix_bs_5 ul[class*="matrix_links_"] > li { \n  width:33.33%; \n  height:72px;\n  padding:0 5px;\n  margin:0 0 10px; \n  float:left;\n  font-size:12px; \n  line-height:1.25; \n  text-align:center; \n  white-space:nowrap; \n} \nmw-matrix .matrix_container ul[class*="matrix_links_"] > li > a,\n.matrix_container_mobile ul[class*="matrix_links_"] > li > a,\n.matrix_container.mw_matrix_bs_5 ul[class*="matrix_links_"] > li > a { \n  width:100%; \n  padding:7px 0 0 0; \n  border:none;\n  color: var(--mw-matrix-link-color);\n  background:transparent; \n  display:block; \n  text-decoration:none !important; \n}\n\nmw-matrix .matrix_container ul[class*="matrix_links_"] > li > a > img,\n.m