:host {
    --mw-opacity-disabled-button : 0.35;
    --mw-backgroundColor-button : var(--mw-backgroundColor-primary);
    --mw-borderRadius-button: 5px;
    --mw-borderStyle-button: solid;
    --mw-borderColor-button:  var(--mw-borderColor-primary);
    --mw-color-button: var(--mw-color-primary);
    --mw-borderLeftWidth-button: 1px;
    --mw-borderRightWidth-button: 1px;
    --mw-borderTopWidth-button: 1px;
    --mw-borderBottomWidth-button: 1px; 
    --mw-borderWidth-button: 1px;
    --mw-display-button:inline-block;
    --mw-activeBackgroundColor-button:var(--mw-backgroundColor-active);
    --mw-activeBorderColor-button:var(--mw-borderColor-primary);
    --mw-activeBoxShadow-button: inset 0 1px 0 0 var(--mw-activeBoxShadowColor-button);
    --mw-focussedBorderColor-button: var(--mw-borderColor-focus);
    --mw-backgroundColor-toggleon-button:var(--mw-backgroundColor-toggleOn);
    --mw-hoverBackgroundColor-toggleon-button:var(--mw-backgroundColor-toggleOn-hover);
    --mw-hoverBorderColor-toggleon-button: var(--mw-borderColor-toggleOn-hover);
    --mw-outline-button: none;
    --mw-fontSize-button: 0.75em;
    --mw-boxshadow-toggleon-button: inset 0 1px 0 0 rgb(0 0 0 / 15%);
    --mw-paddingTop-button: 2px;
    --mw-paddingRight-button: 4px;
    --mw-paddingBottom-button: 2px;
    --mw-paddingLeft-button: 4px;
    --mw-marginTop-button:0;
    --mw-marginRight-button:0;
    --mw-marginBottom-button:0;
    --mw-marginLeft-button:0;
    --mw-whitespace-button:normal;
    --mw-fontFamily-button:Arial;
    --mw-cursor-button:default;
    display: var(--mw-display-button);
    box-sizing: border-box;

}

:host > .mwButton{
    width: 100%;
    height: 100%;
    cursor: var(--mw-cursor-button);
    background-color: var(--mw-backgroundColor-button);
    padding-top: var(--mw-paddingTop-button);
    padding-right: var(--mw-paddingRight-button);
    padding-bottom: var(--mw-paddingBottom-button);
    padding-left: var(--mw-paddingLeft-button);
    margin-top: var(--mw-marginTop-button);
    margin-right: var(--mw-marginRight-button);
    margin-bottom: var(--mw-marginBottom-button);
    margin-left: var(--mw-marginLeft-button);
    font-size: var(--mw-fontSize-button);
    font-family: var(--mw-fontFamily-button);
    border-width: var(--mw-borderWidth-button);
    border-left-width: var(--mw-borderLeftWidth-button);
    border-right-width: var(--mw-borderRightWidth-button);
    border-top-width: var(--mw-borderTopWidth-button);
    border-bottom-width: var(--mw-borderBottomWidth-button);
    border-style: var(--mw-borderStyle-button);
    border-color: var(--mw-borderColor-button);
    border-radius: var(--mw-borderRadius-button);
    color: var(--mw-color-button);
    display: var(--mw-display-button);
    user-select: none;
    -webkit-user-select: none;
    white-space:var(--mw-whitespace-button);
    vertical-align: top;
}

:host > .mwButton:hover{
    background-color: var(--mw-backgroundColor-hover);
    border-color: var(--mw-borderColor-hover);
}

:host > .mwButton:active {
    background-color: var(--mw-activeBackgroundColor-button);
    border-color: var(--mw-activeBorderColor-button);
    box-shadow: var(--mw-activeBoxShadow-button);
}

:host > .mwButton:focus {
    border-color: var(--mw-focussedBorderColor-button);
    outline: var(--mw-outline-button);
}

:host > button[disabled].mwButton {
    outline: var(--mw-outline-button);
    opacity: var(--mw-opacity-disabled-button);
}

:host > button[disabled] ,
:host([disabled]) {
    pointer-events: none;
}

/** Toggle Button Styles **/

:host([checked]) > .mwButton {
    background-color: var(--mw-backgroundColor-toggleon-button);
    border-color: var(--mw-borderColor-button);
    box-shadow: var(--mw-boxshadow-toggleon-button);
}

:host([checked]) > .mwButton:focus {
    border-color: var(--mw-focussedBorderColor-button);
}

:host([checked]) > .mwButton:hover {
    background-color: var(--mw-hoverBackgroundColor-toggleon-button);
    border-color: var(--mw-hoverBorderColor-toggleon-button);
}

:host([checked]) > .mwButton:active {
    background-color: var(--mw-activeBackgroundColor-button);
    border-color: var(--mw-focussedBorderColor-button);
