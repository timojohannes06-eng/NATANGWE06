sion-banner button.primary::after {\n    content: url("+g+");\n    margin-left: 4px;\n    margin-top: 4px;\n    flex-shrink: 0;\n}\n\n\nmw-mos-session-banner .dropdown-content {\n    display: none;\n    position: absolute;\n    top: 45px;\n    right: 10px;\n    width: 200px;\n    background-color: var(--mw-backgroundColor-tertiary);\n    min-width: 160px;\n    padding: 7px 0;\n    z-index: 1;\n    border: 1px solid var(--mw-borderColor-secondary);\n    box-shadow: 0px 2px 4px var(--mw-boxShadowColor);\n}\n\nmw-mos-session-banner .dropdown-content.show {\n    display: block;\n}\n\nmw-mos-session-banner  .dropdown-content .open-menu-item {\n    width: 100%;\n    justify-content: left;\n    border: none;\n    font: inherit;\n    background-color: var(--mw-backgroundColor-tertiary);\n    white-space: pre;\n    cursor: pointer;\n    color: var(--mw-backgroundColor-inputFill);\n    margin: 0;\n    padding: 2px 20px;\n}\n  \nmw-mos-session-banner  .dropdown-content .open-menu-item:hover {\n    background-color: var(--mw-backgroundColor-primary);\n}\n\nmw-mos-session-banner  .dropdown-content .open-menu-item:focus {\n    outline: 2px solid var(--mw-borderColor-focus);\n    outline-offset: -2px;\n}\n\nmw-mos-session-banner .main-content {\n    background: var(--mw-backgroundColor-tertiary);\n}","",{version:3,sources:["webpack://./mw-home-ui/css/SessionBanner.css"],names:[],mappings:"AAAA;IACI,aAAa;IACb,4BAA4B;IAC5B,YAAY;AAChB;;AAEA;IACI,6CAA6C;IAC7C,WAAW;IACX,WAAW;IACX,YAAY;IACZ,kBAAkB;IAClB,SAAS;IACT,SAAS;AACb;;AAEA;IACI,mDAAmD;IACnD,oDAAoD;IACpD,eAAe;IACf,aAAa;IACb,mBAAmB;IACnB,4BAA4B;;AAEhC;;AAEA;IACI,kBAAkB;IAClB,WAAW;IACX,cAAc;IACd,YAAY;IACZ,sBAAsB;IACtB,kBAAkB;IAClB,yDAAkD;AACtD;;AAEA;IACI,YAAY;IACZ,iBAAiB;AACrB;;AAEA;EACE;IACE,gBAAgB;IAChB,YAAY,EAAE,mDAAmD;IACjE,mBAAmB;IACnB,gBAAgB;IAChB,uBAAuB;EACzB;AACF;;AAEA;IACI,aAAa;IACb,SAAS;AACb;;AAEA;IACI,oDAAoD;IACpD,6BAA6B;IAC7B,eAAe;IACf,aAAa;IACb,YAAY;IACZ,2BAA2B;IAC3B,uBAAuB;IACvB,mBAAmB;IACnB,QAAQ;IACR,eAAe;IACf,kBAAkB;I